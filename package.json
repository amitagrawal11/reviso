    "@tabler/icons-react": "^3.19.0",
    "@uiw/react-md-editor": "^4.0.5",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
